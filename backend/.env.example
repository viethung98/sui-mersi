# Required — Neon Postgres (pooler endpoint for application queries)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require&channel_binding=require

# Optional — Neon Postgres (direct endpoint for migrations, no PgBouncer)
# DATABASE_URL_DIRECT=postgresql://user:pass@host/dbname?sslmode=require

# Required — Crossmint (https://www.crossmint.com/console)
OPENAI_API_KEY=sk-your-openai-key
CROSSMINT_SERVER_API_KEY=sk_staging_your-crossmint-key
# CROSSMINT_API_URL=https://staging.crossmint.com

# LLM — OpenRouter (https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=sk-or-your-key-here
LLM_MODEL=openai/gpt-4o

# Optional (with defaults)
PORT=3000
PRODUCT_SERVICE=mock
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info
RATE_LIMIT_RPM=30

# Scraping service (required when PRODUCT_SERVICE=scraping)
# SCRAPING_SERVICE_URL=https://your-scraping-service.com
# SCRAPING_SERVICE_API_KEY=your-api-key

# Deposit webhook secret
# DEPOSIT_WEBHOOK_SECRET=your-webhook-secret
# PAS_TO_USDC_RATE=0.01

# Sui blockchain
# SUI_RPC_URL=https://fullnode.testnet.sui.io:443
# SUI_CONTRACT_ADDRESS=0x<deployed-package-id>
# SUI_CART_REGISTRY_ID=0x<shared-CartRegistry-object-id>   # shared object created by init()
# SUI_RELAYER_PRIVATE_KEY=suiprivkey1...   # Bech32 Sui private key for relayer
# WALLET_ENCRYPTION_KEY=32-byte-hex-key-for-aes-encryption

# Cart service: "db" (default) or "onchain"
# CART_SERVICE=db

# Dev/test only — Sui private key for the dev login and seed-mock-user script
# DEV_SUI_PRIVATE_KEY=suiprivkey1...

# MemWal — verifiable AI memory (optional; memory disabled if not set)
# Get MEMWAL_DELEGATE_KEY and MEMWAL_ACCOUNT_ID from app.memwal.com
# MEMWAL_SERVER_URL=https://relayer.memwal.ai
# MEMWAL_DELEGATE_KEY=
# MEMWAL_ACCOUNT_ID=

# BetterStack log forwarding (optional)
# BETTERSTACK_SOURCE_TOKEN=your-source-token
# BETTERSTACK_INGESTING_HOST=s2380734.eu-fsn-3.betterstackdata.com
