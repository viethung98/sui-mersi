{
	"name": "scraping-service",
	"version": "1.0.0",
	"description": "Amazon Scraping Service",
	"author": "",
	"private": true,
	"license": "MIT",
	"type": "commonjs",
	"scripts": {
		"prebuild": "rimraf dist",
		"build": "nest build",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"start": "nest start",
		"dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./test/jest-e2e.json",
		"mcp": "MCP_MODE=stdio ts-node --transpile-only -r tsconfig-paths/register mcp-server.ts",
		"mcp:http": "ts-node --transpile-only -r tsconfig-paths/register mcp-server.ts",
		"test:sui": "ts-node --skip-project --transpile-only --compiler-options '{\"module\":\"CommonJS\",\"target\":\"ES2021\",\"esModuleInterop\":true}' scripts/test-sui-payment.ts"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@mysten/payment-kit": "^0.1.5",
		"@mysten/sui": "^2.14.1",
		"@nestjs/axios": "^3.0.1",
		"@nestjs/common": "^10.2.10",
		"@nestjs/config": "^3.1.1",
		"@nestjs/core": "^10.2.10",
		"@nestjs/platform-express": "^10.2.10",
		"@nestjs/swagger": "^7.4.2",
		"@nestjs/throttler": "^6.5.0",
		"@nestjs/typeorm": "^10.0.1",
		"apify-client": "^2.22.2",
		"axios": "^1.6.2",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.1",
		"dotenv": "^16.3.1",
		"ioredis": "^5.10.0",
		"pg": "^8.11.3",
		"reflect-metadata": "^0.1.13",
		"rimraf": "^5.0.5",
		"rxjs": "^7.8.1",
		"typeorm": "^0.3.17"
	},
	"devDependencies": {
		"@nestjs/cli": "^10.2.1",
		"@nestjs/schematics": "^10.0.3",
		"@nestjs/testing": "^10.2.10",
		"@types/express": "^4.17.21",
		"@types/jest": "^29.5.11",
		"@types/node": "^20.10.5",
		"@types/supertest": "^2.0.16",
		"@typescript-eslint/eslint-plugin": "^6.15.0",
		"@typescript-eslint/parser": "^6.15.0",
		"eslint": "^8.56.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-prettier": "^5.0.1",
		"jest": "^29.7.0",
		"prettier": "^3.1.1",
		"source-map-support": "^0.5.21",
		"supertest": "^6.3.3",
		"ts-jest": "^29.1.1",
		"ts-loader": "^9.5.1",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.3.3"
	},
	"resolutions": {
		"string-width": "4.2.3"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}
