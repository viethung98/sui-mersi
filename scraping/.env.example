# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_URL=postgres://postgres:your_password@localhost:5432/amazon_shopping_agent
DB_DATABASE=amazon_shopping_agent
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=false

# Apify
APIFY_API_TOKEN=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Comagent webhook
COMAGENT_BASE_URL=http://localhost:3001
DEPOSIT_WEBHOOK_SECRET=

# Test wallet for scripts/test-sui-payment.ts
TEST_SUI_PRIVATE_KEY=

# Sui (Payment Kit SDK)
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_MERCHANT_ADDRESS=
SUI_PAYMENT_AMOUNT_MIST=1000000000
SUI_COIN_TYPE=0x2::sui::SUI
SUI_REGISTRY_NAME=
